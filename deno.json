{
  "name": "@rendly/bedrockjs",
  "version": "0.1.3",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./html": "./src/html.ts",
    "./render": "./src/render.ts",
    "./component": "./src/component.ts",
    "./reactive": "./src/reactive.ts",
    "./router": "./src/router.ts",
    "./sync": "./src/sync/index.ts",
    "./sync/server": "./src/sync/server-entry.ts"
  },
  "publish": {
    "include": [
      "README.md",
      "changelog.md",
      "package.json",
      "src/**/*.d.ts",
      "src/**/*.js",
      "src/**/*.ts",
      "src/sync/README.md"
    ],
    "exclude": [
      "src/sync/__tests__"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "tasks": {
    "dev": "PORT=3000 deno run --unstable-kv --allow-net --allow-read --allow-env examples/sync/server.ts",
    "dev:open": "sh -c \"PORT=3000 deno run --unstable-kv --allow-net --allow-read --allow-env examples/sync/server.ts & sleep 0.5; (xdg-open http://localhost:3000/examples/ || open http://localhost:3000/examples/)\"",
    "examples": "PORT=3000 deno run --unstable-kv --allow-net --allow-read --allow-env examples/sync/server.ts",
    "examples:open": "sh -c \"PORT=3000 deno run --unstable-kv --allow-net --allow-read --allow-env examples/sync/server.ts & sleep 0.5; (xdg-open http://localhost:3000/examples/ || open http://localhost:3000/examples/)\"",
    "sync:dev": "PORT=3000 deno run --unstable-kv --allow-net --allow-read --allow-env examples/sync/server.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-ffi --unstable-kv src/sync/__tests__/"
  }
}
